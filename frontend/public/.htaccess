# SPA routing for Apache shared hosting (Hostinger).
# Vite copies public/ into dist/, so this ships with `npm run build`.
# Upload the CONTENTS of frontend/dist/ to public_html (not the repo).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
